part_summary <- raw %>%
group_by(PROLIFIC_PID,
demographics.age,
demographics.musicianIdentification,
demographics.education) %>%
summarise(mean_believability = mean(believability, na.rm = TRUE),
sd_believability   = sd(believability,   na.rm = TRUE),
.groups = "drop")
head(part_summary, 10)
cor_results <- data.frame(
Predictor = c("Musician identification", "Education level", "Age"),
r = NA_real_, t = NA_real_, df = NA_integer_, p = NA_real_
)
tests <- list(
cor.test(part_summary$demographics.musicianIdentification,
part_summary$mean_believability, method = "pearson"),
cor.test(part_summary$demographics.education,
part_summary$mean_believability, method = "pearson"),
cor.test(part_summary$demographics.age,
part_summary$mean_believability, method = "pearson")
)
for (i in seq_along(tests)) {
cor_results$r[i]  <- round(tests[[i]]$estimate,   3)
cor_results$t[i]  <- round(tests[[i]]$statistic,  3)
cor_results$df[i] <- tests[[i]]$parameter
cor_results$p[i]  <- round(tests[[i]]$p.value,    4)
}
cor_results
