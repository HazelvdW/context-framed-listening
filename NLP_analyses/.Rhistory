library(matrixStats)
library(lme4)
library(lmerTest)
library(effects)
library(afex)
library(Hmisc)
library(ggeffects)
library(ggplot2)
library(ggforce)
library(knitr)
library(dplyr)
path1 <- "/Users/hazelaileenvanderwalle/Library/CloudStorage/OneDrive-Personal/work/study/PhD/_PROJECT/_framedListening_NLP/data/analyses/mainstudydata"
setwd(path1)
fileNames <- dir(pattern = "*.csv")
# setting a "for" loop to read in each datafile
read1 <- list()
for (i in 1:length(fileNames)) {
rawdata1=read.csv(fileNames[i],header=T,fileEncoding="UTF-8-BOM")
clip_name=rawdata1$clip_file_loc[c(14:16,18:21,23:26,28:32)] #row locations
clip_name=substr(clip_name,11,nchar(clip_name)) #remove "resources/" from clip names
context_word=rawdata1$context_cue_text[c(14:16,18:21,23:26,28:32)] #row locations
context_word=dplyr::case_when(
grepl("bar",        context_word, ignore.case=TRUE) ~ "bar",
grepl("concert",    context_word, ignore.case=TRUE) ~ "concert",
grepl("video game", context_word, ignore.case=TRUE) ~ "videogame",
grepl("movie",      context_word, ignore.case=TRUE) ~ "movie",
TRUE ~ NA_character_
)
data1=rawdata1
# NA fill-ins for empty free-text thought responses:
if(any(data1$descr_THOUGHT.text == "" | is.na(data1$descr_THOUGHT.text)))
{data1[data1$descr_THOUGHT.text == "" |is.na(data1$descr_THOUGHT.text),'descr_THOUGHT.text']   = NA
}
if(any(data1$input_NOT.text == "" | is.na(data1$input_NOT.text)))
{data1[data1$input_NOT.text == "" | is.na(data1$input_NOT.text), 'input_NOT.text'] = NA
}
# Add columns to log demographic information etc.
data1$File_ID=fileNames[i]
data1$demographics.headphones=data1$demographics.headphones[33]
data1$demographics.age=data1$demographics.age[33]
data1$demographics.gender=data1$demographics.gender[33]
data1$demographics.livingCountry=data1$demographics.livingCountry[33]
data1$demographics.birthCountry=data1$demographics.birthCountry[33]
data1$demographics.nativeLanguage=data1$demographics.nativeLangue[33]
data1$demographics.otherLanguage=data1$demographics.otherLanguage[33]
data1$demographics.hearingImpariments=data1$demographics.hearingImpariments[33]
data1$demographics.education=data1$demographics.education[33]
data1$demographics.musicianIdentification=data1$demographics.musicianIdentification[33]
data1$demographics.feedback=data1$demographics.feedback[33]
data1$demographics.otherLanguageText=data1$demographics.otherLanguageText[33]
data1$demographics.hearingImpairmentsText=data1$demographics.hearingImpairmentsText[33]
# Ensure all expected columns exist
expected_cols <- c('expName','PROLIFIC_PID','File_ID','date',
'response_thought_or_not.keys','descr_THOUGHT.text',
'rating_music_prompted.response','rating_spontaneity.response',
'rating_novelty.response','input_NOT.text',
'rating_familiarity.response','rating_enjoyment.response',
'demographics.headphones','demographics.age',
'demographics.gender','demographics.livingCountry',
'demographics.birthCountry','demographics.nativeLanguage',
'demographics.otherLanguage','demographics.otherLanguageText',
'demographics.hearingImpariments','demographics.hearingImpairmentsText',
'demographics.education','demographics.musicianIdentification',
'demographics.feedback')
for(col in expected_cols) {
if(!col %in% colnames(data1)) {
data1[, col] <- NA
}
}
colorder <- c('expName','PROLIFIC_PID','File_ID','date',
'response_thought_or_not.keys','descr_THOUGHT.text',
'rating_music_prompted.response','rating_spontaneity.response',
'rating_novelty.response','input_NOT.text',
'rating_familiarity.response','rating_enjoyment.response',
'demographics.headphones','demographics.age',
'demographics.gender','demographics.livingCountry',
'demographics.birthCountry','demographics.nativeLanguage',
'demographics.otherLanguage','demographics.otherLanguageText',
'demographics.hearingImpariments','demographics.hearingImpairmentsText',
'demographics.education','demographics.musicianIdentification',
'demographics.feedback')
data1<-data1[c(14:17,19:22, 24:26, 28:32),colorder]
data1<-cbind(context_word,data1)
data1<-cbind(clip_name,data1)
data1 -> read1[[i]]
}
# Apply this function to all .csv files and convert resulting list into a single dataframe
dataMAINstudy <- do.call(rbind, read1)
write.csv(dataMAINstudy, file="/Users/hazelaileenvanderwalle/Library/CloudStorage/OneDrive-Personal/work/study/PhD/_PROJECT/_framedListening_NLP/data/analyses/dataMAINstudy.csv", row.names = FALSE)
