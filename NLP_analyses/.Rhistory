t_context_results <- do.call(rbind, lapply(levels(raw$context_word), function(ctx) {
d  <- raw$believability[raw$context_word == ctx]
tt <- t.test(d, mu = 3)
data.frame(
context = ctx,
M       = round(tt$estimate,      3),
t       = round(tt$statistic,     3),
df      = tt$parameter,
p       = round(tt$p.value,       4),
CI_low  = round(tt$conf.int[1],   3),
CI_high = round(tt$conf.int[2],   3)
)
}))
t_context_results
